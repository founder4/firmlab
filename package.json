{
  "name": "firmlab",
  "version": "0.1.0",
  "private": true,
  "description": "FirmLab — local-only firmware analysis workbench (structure map, entropy, filesystem, SBOM, emulation).",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "check": "pnpm -r run check",
    "test": "pnpm -r run test",
    "dev:api": "pnpm --filter @firmlab/api run dev",
    "dev:web": "pnpm --filter @firmlab/web run dev",
    "biome": "biome check .",
    "biome:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
